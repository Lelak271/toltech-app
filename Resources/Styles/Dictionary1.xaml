<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:TOLTECH_APPLICATION.Resources.Styles">

    <conv:StringNullOrEmptyToVisibilityConverter x:Key="TextAndFocusToVisibilityConverter" />

    <!-- Style : placeholder classique, hint visible uniquement quand Text est vide -->
    <Style x:Key="CustomHintTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="LightGray" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="FontSize" Value="14" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="2"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch" />

                        <!-- Hint : Visibility déterminée par un MultiBinding (Text, IsKeyboardFocused) -->
                        <TextBlock x:Name="HintText"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="Gray"
                                   Margin="4,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   IsHitTestVisible="False"
                                   FontSize="12"
                                   Opacity="0.8">
                            <TextBlock.Visibility>
                                <MultiBinding Converter="{StaticResource TextAndFocusToVisibilityConverter}">
                                    <!-- binding 0 : Text -->
                                    <Binding Path="Text" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <!-- binding 1 : IsKeyboardFocused -->
                                    <Binding Path="IsKeyboardFocused" RelativeSource="{RelativeSource TemplatedParent}" />
                                </MultiBinding>
                            </TextBlock.Visibility>
                        </TextBlock>
                    </Grid>

                    <!-- (Optionnel) triggers supplémentaires si vous voulez modifier l'apparence au focus -->
                    <ControlTemplate.Triggers>
                        <!-- Exemple : si vous voulez changer l'opacité du hint quand contrôle vide ET focus (mais ici hint est Collapsed) -->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
