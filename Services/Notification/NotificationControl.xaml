<UserControl x:Class="Toltech.App.Services.Notification.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Toltech.App.FrontEnd.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="1500">

    <Border  Opacity="0.95" Padding="0" Width="auto" MaxWidth="800" MinWidth="350" Cursor="Hand" MouseLeftButtonDown="OnNotificationClicked">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <!-- hauteur fine -->
            </Grid.RowDefinitions>

            <Border x:Name="HeaderNotif" 
                    Background="#0078D7" 
                    CornerRadius="10,10,0,0"
                    Padding="6" 
                     >
                <TextBlock Text="Notification Toltech"  FontWeight="Bold" Foreground="White" FontSize="12"/>
            </Border>

            <Grid Grid.Row="1" Width="auto">
                <Border x:Name="FirstLoadingProgress" Background="#B3D9FF" VerticalAlignment="Stretch" CornerRadius="0,0,10,10" />
                <Border x:Name="LoadingProgress" Background="#7FB8E8" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="0" CornerRadius="0,0,10,10"/>

                <TextBlock x:Name="MessageText" FontSize="16" Padding="10" Foreground="Black" 
                    HorizontalAlignment="Left" TextWrapping="Wrap"/>
            </Grid>

            <ProgressBar x:Name="ProgressBar" Grid.Row="2" Minimum="0" Maximum="100" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 Background="Transparent" Foreground="#00BFFF" BorderThickness="0" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                 Margin="0,-6,0,0"/>
        </Grid>

    </Border>
</UserControl> 