<Application x:Class="Toltech.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:Fluent="urn:fluent-ribbon"
             xmlns:local="clr-namespace:Toltech.App" 
             StartupUri="Views/Pages/MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                
                <!-- Thème statique -->
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Fluent;component/Themes/Generic.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/Generic.xaml" />


                <ResourceDictionary Source="pack://application:,,,/Toltech.App;component/StylesApp.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Toltech.App;component/Resources/Styles/MainStyles.xaml" />


            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>
