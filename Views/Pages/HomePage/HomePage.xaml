<UserControl xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"  
      x:Class="Toltech.App.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lang="clr-namespace:Toltech.App.Resources.Lang"
             >
    <Border Style="{DynamicResource BorderThemeStyle}" Margin="0">
        <Border.Background >
            <SolidColorBrush Color="{DynamicResource PrimaryBackgroundColor}" Opacity="0.7" />
        </Border.Background>
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Name="HeaderPage1" Background="{DynamicResource PrimaryBackgroundBrush}" Opacity="0.5" Padding="20" CornerRadius="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Asset/Logo_TT.png" Width="auto" Height="50" Margin="0,0,10,0"/>
                    <TextBlock Text="{lang:Loc AppTitle}" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Name="MainPage1" Grid.Row="1"  Margin="10,10,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Texte de présentation -->
                <StackPanel Margin="0">
                    <TextBlock Text="{Binding AppVersion}" />
                    <TextBlock Text="{Binding NameApp}" />
                    <TextBlock Text="{Binding Framework}" />
                    <TextBlock Text="{lang:Loc AppDescription1}" FontSize="16" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock Text="{lang:Loc AppDescription2}" FontSize="16" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock Text="{lang:Loc AppCreator}" FontSize="14"  FontStyle="Italic" TextWrapping="Wrap"/>
                    <Image Grid.Column="1"  Source="/Asset/Logo_TT.png" Stretch="Uniform"  HorizontalAlignment="Center"  VerticalAlignment="Center"
                       Width="300" Height="300"  Margin="0,0,0,0" />
                    <TextBlock Text="VERSION - BETA" FontSize="60" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"
                               TextWrapping="Wrap">
                        <TextBlock.Background>
                            <SolidColorBrush Color="#E74C3C"/>
                            <!-- Rouge vif pour attirer l'attention -->
                        </TextBlock.Background>
                        <TextBlock.Padding>10</TextBlock.Padding>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- Deuxième colonne : To-Do List -->
                <Grid Grid.Column="1" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <TextBlock Grid.Row="0" Text="To-Do List Beta Features" FontSize="18" FontWeight="Bold"
                                  Margin="0,0,0,10" />

                    <!-- Liste -->
                    <ListBox Grid.Row="1" x:Name="ToDoListBox" ItemsSource="{Binding ToDoItems}" BorderThickness="1"
                              BorderBrush="#CCCCCC" Background="{DynamicResource SecondaryBackgroundBrush}" Opacity="0.7" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <CheckBox IsChecked="{Binding IsDone}" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Title}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!--<Image Grid.Row="2"  Source="/Asset/TimeLine.png" Margin="0,10,0,10" Stretch="Uniform" Visibility="Visible" />-->
                    <Viewbox Visibility="Collapsed" Grid.Row="2" Width="128" Height="128" Stretch="Uniform">
