<UserControl x:Class="TOLTECH_APPLICATION.FrontEnd.Controls.Dashboard.PieChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="clr-namespace:TOLTECH_APPLICATION.Resources.Lang"
             xmlns:local="clr-namespace:TOLTECH_APPLICATION.FrontEnd.Controls.Dashboard"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource PrimaryBackgroundBrush}"
             BorderBrush="Transparent"
             d:DesignHeight="450" d:DesignWidth="800">

    <GroupBox Header="Diagramme Camembert — Contribution par pièce"
              FontWeight="Bold" Margin="5"
              BorderBrush="{DynamicResource TertiaryBackgroundBrush}"
              Background="{DynamicResource SecondaryBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Zone de configuration ── -->
            <Grid Grid.Row="0" Margin="5,15,5,5" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sélection de l'exigence -->
                <StackPanel Grid.Column="0" Margin="0">
                    <TextBlock Text="Exigence" FontSize="11" Margin="0,0,0,2"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                    <ComboBox x:Name="ReqCombo" Width="200" Margin="0,0,0,5"
                              SelectionChanged="ReqCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Bouton Rafraîchir -->
                <Button Grid.Column="1" Click="RefreshButton_Click"
                        Margin="10,0,0,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="⟳" FontSize="35" HorizontalAlignment="Center" Margin="0,-10,0,5"/>
                        <TextBlock Text="Rafraîchir" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Type de contribution -->
                <StackPanel Grid.Column="2" Margin="20,0,0,0" VerticalAlignment="Top">
                    <TextBlock Text="Afficher" FontSize="11" Margin="0,0,0,4"
                               Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                    <RadioButton x:Name="RadioByPart"    Content="Par exigence"      IsChecked="True"
                                 GroupName="PieGroup" Checked="RadioMode_Checked"/>
                    <RadioButton x:Name="RadioByType"    Content="Toutes les exigences"
                                 GroupName="PieGroup" Checked="RadioMode_Checked"/>
                </StackPanel>

            </Grid>

            <!-- ── Pas de données ── -->
            <Grid Grid.Row="1" x:Name="NoDataImage">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Image Width="Auto" Height="Auto" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Source="/Asset/EmptyData.jpg" Stretch="Uniform" Panel.ZIndex="999"/>
                <TextBlock Grid.Row="1" Text="Pas de données pour le moment..."
                           Style="{StaticResource EmptyDataTextBlockStyle}"/>
            </Grid>

            <!-- ── Zone graphique ── -->
            <Grid Grid.Row="1" x:Name="ChartArea" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Camembert -->
                <lvc:PieChart x:Name="PieChart"
                              Grid.Column="0"
                              Margin="10"
                              LegendPosition="Hidden"
                              TooltipPosition="Auto"
                              Panel.ZIndex="998"/>

                <!-- Légende personnalisée -->
                <Border Grid.Column="1" Margin="5,10,10,10"
                        BorderBrush="{DynamicResource PrimaryBorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Background="{DynamicResource PrimaryBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel x:Name="LegendPanel"/>
                    </ScrollViewer>
                </Border>
            </Grid>

        </Grid>
    </GroupBox>
</UserControl>
