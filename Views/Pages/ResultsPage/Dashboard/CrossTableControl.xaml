<UserControl x:Class="Toltech.App.FrontEnd.Controls.Dashboard.CrossTableControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Toltech.App.FrontEnd.Controls"
             xmlns:lang="clr-namespace:Toltech.App.Resources.Lang"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800"
             Background="{DynamicResource SecondaryBackgroundBrush}">

    <GroupBox Header="Tableau croisé des résultats" FontWeight="Bold" Margin="5">
        <DockPanel LastChildFill="True" Margin="0,15,0,0">

            <!-- Entête : ComboBox + boutons -->
            <Grid  DockPanel.Dock="Top" Margin="5" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Vertical" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{lang:Loc Table_type}" 
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="CbCrossTableVariant" 
                              Width="260" 
                              DisplayMemberPath="Value" 
                              SelectedValuePath="Key"
                              SelectionChanged="CbCrossTableVariant_SelectionChanged"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="{lang:Loc Model_analyzed}"/>
                    <TextBlock Text="{Binding FileResxName}" VerticalAlignment="Center" FontWeight="ExtraLight" Margin="0"/>
                </StackPanel>

                <!-- Boutons export -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button Name="BtnGenererCrossTable" ToolTip="{lang:Loc Export_CrossTable_to_Excel}" Click="ButtonGenererCrossTable_Click" Margin="0,0,10,0">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Image Source="/Asset/logo_excel.png" Width="32" Height="32" Stretch="Uniform"/>
                            <TextBlock Text="{lang:Loc Export_to_Excel}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Name="BtnGenererGSheet" ToolTip="{lang:Loc Export_CrossTable_to_Google_Sheets}" Click="BtnGenererGSheet_Click">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Image Source="/Asset/logo_gsheet.png" Width="32" Height="32" Stretch="Uniform"/>
                            <TextBlock Text="{lang:Loc Export_to_GSheet}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid DockPanel.Dock="Bottom" Margin="5,15,5,5" x:Name="NoDataImage">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Image    Width="auto"
                          Height="auto"
                          Source="/Asset/EmptyData.jpg" Margin="0" Stretch="Uniform" Visibility="Visible" Panel.ZIndex="999" />
                <TextBlock Grid.Row="1" 
                           Text="Pas de données pour le moment..." 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="25"
                           FontWeight="SemiBold"
                           FontFamily="Century Gothic" 
                           Foreground="#FF5A5A5A" 
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Opacity="0.9"
                           Margin="10"  />

            </Grid>
            
            <!-- DataGrid -->
            <DataGrid x:Name="ResultsCrossTable"
                      AutoGenerateColumns="True"
                      AutoGeneratingColumn="ResultsCrossTable_AutoGeneratingColumn"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="All"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="AliceBlue"
                      AlternationCount="2"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center"
                      Margin="5"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1"
                      FontSize="13"
                      FontFamily="Segoe UI"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow">

                <DataGrid.Resources>

                    <!-- Style des en-têtes -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="SlateGray"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="BorderBrush" Value="#C5D0E6"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Height" Value="30"/>
                    </Style>
                    
                    <!-- Style des cellules -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>

                        <Style.Triggers>
                            <!-- Alternance des lignes -->
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(ItemsControl.AlternationIndex)}" Value="0">
                                <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
                            </DataTrigger>

                            <!-- Cellule sélectionnée -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="FontWeight" Value="Heavy"/>
                                <Setter Property="FontStyle" Value="Oblique"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <!-- Style des lignes -->
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <!--UX moderne -->

                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#C9E6FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                </DataGrid.Resources>
            </DataGrid>

        </DockPanel>
    </GroupBox>
</UserControl>
