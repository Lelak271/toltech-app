<UserControl x:Class="Toltech.App.FrontEnd.Controls.Dashboard.BChartReqs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Toltech.App.FrontEnd.Controls.Dashboard"
             xmlns:lang="clr-namespace:Toltech.App.Resources.Lang"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource SecondaryBackgroundBrush}">

    <!-- Conteneur principal -->
    <GroupBox Header="Diagramme par exigence" FontWeight="Bold" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Zone de configuration -->
            <Grid Grid.Row="0" Margin="5,15,5,5" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Bouton Actualiser -->
                    <ColumnDefinition Width="30"/>
                    <!-- Espacement -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Zone Filtre -->
                </Grid.ColumnDefinitions>

                <!-- Bouton Actualiser -->
                <Button Grid.Column="0"
            Click="Load_Click"
            VerticalAlignment="Top"
            Padding="10,6"
            Cursor="Hand">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="⟳"
                                   FontSize="35"
                                   HorizontalAlignment="Center"
                                   Margin="0,-10,0,5"/>
                        <TextBlock Text="{lang:Loc Refresh}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>   
                    </StackPanel>
                </Button>

                <!-- Bloc Filtrage -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{lang:Loc FilterBy}" Grid.Row="0" HorizontalAlignment="Center" Margin="0,5,0,5" FontSize="13"
                               FontWeight="SemiBold" Foreground="#FF3A3A3A"/>

                    <ComboBox Grid.Row="1" Width="130" HorizontalAlignment="Center" SelectionChanged="FilterCombo_SelectionChanged" FontSize="13">
                        <ComboBoxItem Content="Défaut" Tag="Default" IsSelected="True"/>
                        <ComboBoxItem Content="Par max" Tag="ByMax"/>
                        <ComboBoxItem Content="Par min" Tag="ByMin"/>
                    </ComboBox>
                </Grid>
            </Grid>


            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" 
                           Text="{lang:Loc ContributionsByRequirement}" 
                           FontSize="18" 
                           FontWeight="Bold"
                           Margin="0,0,0,0"/>

                <Grid Grid.Row="1" x:Name="NoDataImage" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Image  Width="auto"
                            Height="auto" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                           Source="/Asset/EmptyData.jpg" 
                            Margin="0" 
                            Stretch="Uniform"
                            Visibility="Visible" 
                            Panel.ZIndex="999" />
                    <TextBlock Grid.Row="1" 
                               Text="Pas de données pour le moment..."
                               FontSize="25"
                               FontWeight="SemiBold"
                               FontFamily="Century Gothic"
                               Foreground="#FF5A5A5A" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center"
                               Opacity="0.9"
                               Margin="10"  />

                </Grid>
                
                <!-- Zone graphique -->
                <ScrollViewer Grid.Row="1"  
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                
                    <lvc:CartesianChart x:Name="BarChartReqs"
                                        TooltipPosition="Auto"
                                        ZoomMode="X" 
                                        ZoomingSpeed="0" 
                                        MinHeight="400"
                                        MinWidth="800" />
                </ScrollViewer>
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
