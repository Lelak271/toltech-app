<Window x:Class="TOLTECH_APPLICATION.FrontEnd.Controls.Dashboard.SupplementaryParamsBarChart"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Paramètres Chart" Height="650" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="520" MinHeight="380">

   
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Personnalisation des couleurs et traits" 
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

        <!-- Corps -->
        <Grid Grid.Row="1" ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <Expander Header="Paramètres des Colonnes" Width="220" IsExpanded="True" FontWeight="Bold" Margin="10,5" HorizontalAlignment="Left" >
                    <Border Background="#FFFFFF" CornerRadius="6" BorderThickness="1" BorderBrush="#E1E5EB" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,15">
                                    <Border Width="4" Background="LightBlue" Margin="0,0,12,0" CornerRadius="2"/>
                                    <StackPanel>
                                    <TextBlock Text="Remplissage" FontWeight="SemiBold" Foreground="#2D3E50" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <StackPanel Margin="0">
                                            <TextBlock Text="Colonne 1" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="ColumnFill1Picker" SelectedColor="LawnGreen" Width="100" Height="28" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,5,15,0">
                                            <TextBlock Text="Colonne 2" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="ColumnFill2Picker" SelectedColor="LightBlue" Width="100" Height="28" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,5,15,0">
                                            <TextBlock Text="Colonne 3" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="ColumnFill3Picker" SelectedColor="Salmon" Width="100" Height="28" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Grid.Row="2" Height="1" Fill="#E1E5EB" Margin="0,0,0,15"/>

                            <!-- Section Contour -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border Width="4" Background="Orange" Margin="0,0,12,0" CornerRadius="2"/>
                                    <StackPanel>
                                    <TextBlock Text="Contour" FontWeight="SemiBold" Foreground="#2D3E50" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Vertical" >
                                            <TextBlock Text="Couleur" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="ColumnOutlinePicker" SelectedColor="Black" Width="100" Height="28" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Épaisseur" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <StackPanel Orientation="Horizontal" >
                                                <Slider x:Name="ColumnStrokeThicknessSlider" Minimum="0" Maximum="8" Value="1.5" TickFrequency="0.5" Width="auto" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Value, ElementName=ColumnStrokeThicknessSlider, StringFormat={}{0:F1}pt}" Foreground="#7F8C9A" FontSize="11" 
                                                           MinWidth="30" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                                <Rectangle Grid.Row="4" Height="1" Fill="#E1E5EB" Margin="0,0,0,15"/>

                                <!-- Section Autres -->
                                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border Width="4" Background="Pink" Margin="0,0,12,0" CornerRadius="2"/>
                                    <StackPanel>
                                        <TextBlock Text="Autres" FontWeight="SemiBold" Foreground="#2D3E50" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Vertical" >
                                                <TextBlock Text="Espacement" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal" >
                                                    <Slider x:Name="BarWidthThicknessSlider" Minimum="1" Maximum="60" Value="50" TickFrequency="1" Width="auto" Margin="0,0,10,0"/>
                                                    <TextBlock Text="{Binding Value, ElementName=BarWidthThicknessSlider, StringFormat={}{0:F0}pt}" Foreground="#7F8C9A" FontSize="11" 
                                                                  MinWidth="30" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                    </Border>
                </Expander>


                    <!-- GroupBox Lignes -->
                <Expander Header="Paramètres Lignes" Width="220" IsExpanded="True" FontWeight="Bold" Margin="10,5" HorizontalAlignment="Left">
                    <Border Background="#FFFFFF" CornerRadius="6" BorderThickness="1" BorderBrush="#E1E5EB" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <CheckBox x:Name="CheckHideLine" Content="Masquer ligne"  />
                                </StackPanel>
                            
                                <Rectangle Grid.Row="1" Height="1" Fill="#E1E5EB" Margin="0,0,0,10"/>
                            
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Ligne" FontWeight="SemiBold" Foreground="#2D3E50" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                            <StackPanel Margin="0">
                                                <TextBlock Text="Couleur" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                                <xctk:ColorPicker x:Name="LineStrokePicker" SelectedColor="Red" Width="100" Height="28" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,5,0,0">
                                                <TextBlock Text="Épaisseur" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Slider x:Name="LineStrokeThicknessSlider" Minimum="0" Maximum="8" Value="2" TickFrequency="0.5" Width="auto" HorizontalAlignment="Stretch"/>
                                                    <TextBlock Text="{Binding Value, ElementName=LineStrokeThicknessSlider, StringFormat={}{0:F1}pt}" Foreground="#7F8C9A" FontSize="11"
                                               MinWidth="30" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                             </StackPanel>
                            
                            <Rectangle Grid.Row="3" Height="1" Fill="#E1E5EB" Margin="0,0,0,15"/>
                           
                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Border Width="4" Background="#F5A623" Margin="0,0,12,0" CornerRadius="2"/>
                                <StackPanel>
                                    <TextBlock Text="Marqueurs (points)" FontWeight="SemiBold" Foreground="#2D3E50" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <StackPanel Margin="0">
                                            <TextBlock Text="Couleur de remplissage" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="LineGeometryFillPicker" SelectedColor="Purple" Width="100" Height="28" HorizontalAlignment="Left"
                                              ToolTip="Couleur de remplissage du marqueur"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,5,0,0">
                                            <TextBlock Text="Couleur du contour" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <xctk:ColorPicker x:Name="LineGeometryStrokePicker" SelectedColor="Red" Width="100" Height="28" HorizontalAlignment="Left"
                                              ToolTip="Couleur du contour du marqueur"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,5,0,0">
                                            <TextBlock Text="Taille" Foreground="#5A6B7C" Margin="0,0,0,5" FontSize="12"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="LineGeometrySizeSlider" Minimum="0" Maximum="20" Value="8" TickFrequency="1" Width="auto" HorizontalAlignment="Stretch"/>
                                                <TextBlock Text="{Binding Value, ElementName=LineGeometrySizeSlider, StringFormat={}{0:F1}pt}" Foreground="#7F8C9A" FontSize="11"
                                           MinWidth="30" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
                </StackPanel>
            </ScrollViewer>

            <!-- Aperçu -->
            <Border Grid.Column="2" Background="#FFF" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="Aperçu" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton x:Name="RadioInfluence" Content="Mode : Influence" GroupName="ChartMode" IsChecked="True"
                                 Checked="RadioInfluence_Checked" Margin="0,0,12,0"/>
                        <RadioButton x:Name="RadioContrib" Content="Mode : Contrib" GroupName="ChartMode" 
                                  Checked="RadioContrib_Checked"  />

                    </StackPanel>
                    <lvc:CartesianChart x:Name="PreviewChart" Height="400" ZoomMode="None" DrawMargin="{Binding RelativeSource={RelativeSource Self}}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton x:Name="ThemeDefaultButton" Content="Thème par défaut" GroupName="ThemeGroup" IsChecked="True" Margin="4"
                                       Checked="ThemeButton_Checked"/>
                        <RadioButton x:Name="Theme1Button" Content="Thème 1" GroupName="ThemeGroup" Margin="4"
                                       Checked="ThemeButton_Checked"/>
                        <RadioButton x:Name="Theme2Button" Content="Thème 2" GroupName="ThemeGroup" Margin="4"
                                       Checked="ThemeButton_Checked"/>
                    </StackPanel>
                    <TextBlock Text="Les modifications sont appliquées dans l'aperçu; cliquez OK pour sauvegarder." FontSize="11" Foreground="Gray" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Boutons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="90" Margin="6,0" Click="OkButton_Click"/>
            <Button Content="Annuler" Width="90" Margin="6,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
