<UserControl x:Class="TOLTECH_APPLICATION.FrontEnd.Controls.Dashboard.BarChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lang="clr-namespace:TOLTECH_APPLICATION.Resources.Lang"
             xmlns:local="clr-namespace:TOLTECH_APPLICATION.FrontEnd.Controls.Dashboard"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             Background="{DynamicResource PrimaryBackgroundBrush}"
             BorderBrush="Transparent"
             d:DesignHeight="450" d:DesignWidth="800"
             >

    <GroupBox Header="{lang:Loc Header_BarChart}" FontWeight="Bold" Margin="5"   
              BorderBrush="{DynamicResource TertiaryBackgroundBrush}" Background="{DynamicResource SecondaryBackgroundBrush}"  >
        <Grid> 
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Zone de configuration -->
            <Grid Grid.Row="0" Margin="5,15,5,5" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Colonne de saisie -->
                <StackPanel Grid.Column="0" Margin="0">
                    <ComboBox x:Name="ReqCombo" Width="200" Margin="0,0,0,5"
                              SelectionChanged="ReqCombo_SelectionChanged"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBox x:Name="UReq" Style="{DynamicResource NumericTextBoxStyle}" Width="66" IsReadOnly="True" HorizontalContentAlignment="Center"/>
                        <TextBox x:Name="VReq" Style="{DynamicResource NumericTextBoxStyle}" Width="66" IsReadOnly="True" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                        <TextBox x:Name="WReq" Style="{DynamicResource NumericTextBoxStyle}" Width="66" IsReadOnly="True" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Center">
                        <Border Style="{DynamicResource BorderThemeStyle}" BorderThickness="1" CornerRadius="5" Height="20" VerticalAlignment="Center">
                            <TextBlock x:Name="FreeDirection" Text="{lang:Loc FREE_DIR_Mode}" FontSize="10" Padding="5"/>
                        </Border>
                        <CheckBox x:Name="CkeckBoxFreeDir" Margin="10,0,0,0" Checked="CheckBoxFreeDir_Checked" Unchecked="CheckBoxFreeDir_Unchecked"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Click="RefreshButton_Click" Margin="10,0,0,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="⟳" FontSize="35" HorizontalAlignment="Center" Margin="0,-10,0,5"/>
                        <TextBlock Text="{lang:Loc Refresh}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Influence / Contribution -->
                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                    <RadioButton x:Name="BoxInfl" Content="{lang:Loc Influence}" IsChecked="True" GroupName="OptionsGroup" Checked="GlobalRefreshButton_Click"/>
                    <RadioButton x:Name="BoxContrib" Content="{lang:Loc Contribution}" GroupName="OptionsGroup" Checked="GlobalRefreshButton_Click"/>
                </StackPanel>

                <!-- Séparateur -->
                <Border Grid.Column="3" Width="1" Margin="10,0"/>

                <!-- WC / RSS -->
                <StackPanel Grid.Column="4" Margin="15,0,0,0">
                    <RadioButton x:Name="BoxWC" Content="{DynamicResource WorstCase}" IsChecked="True" GroupName="OptionsGroup1" Checked="GlobalRefreshButton_Click"/>
                    <RadioButton x:Name="BoxRSS" Content="{DynamicResource StatistiqueWord}" GroupName="OptionsGroup1" Checked="GlobalRefreshButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="15,0,0,0" Orientation="Vertical" VerticalAlignment="Top" >

                    <!-- ComboBox de tri -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock Text="{lang:Loc FilterBy}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="BarChartSortComboBox" SelectedIndex="0" Width="200" 
                                  SelectionChanged="BarChartSortComboBox_SelectionChanged">
                            <ComboBoxItem Content="{lang:Loc Filter_MaxInfluence_Content}" Tag="ByMaxInfl"  ToolTip="{lang:Loc Filter_MaxInfluence}" />
                            <ComboBoxItem Content="{lang:Loc Filter_MinInfluence_Content}" Tag="ByMinInfl"  ToolTip="{lang:Loc Filter_MinInfluence}" />
                            <ComboBoxItem Content="{lang:Loc Filter_TotalContribution_Content}" Tag="ByContrib"     ToolTip="{lang:Loc Filter_TotalContribution}" />
                            <ComboBoxItem Content="{lang:Loc Filter_OriginContribution_Content}" Tag="ByContribOri"  ToolTip="{lang:Loc Filter_OriginContribution}" />
                            <ComboBoxItem Content="{lang:Loc Filter_IntermediateContribution_Content}" Tag="ByContribInt"  ToolTip="{lang:Loc Filter_IntermediateContribution}" />
                            <ComboBoxItem Content="{lang:Loc Filter_EndContribution_Content}" Tag="ByContribExtr" ToolTip="{lang:Loc Filter_EndContribution}" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Options CheckBox -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,0" >

                        <!-- Exclure valeurs nulles ou zéro -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                            <CheckBox x:Name="CheckExcludeNullZero" Width="20" Height="20" VerticalAlignment="Center"
                      IsChecked="True" Checked="GlobalRefreshButton_Click" Unchecked="GlobalRefreshButton_Click"/>
                            <TextBlock Text="{lang:Loc ExcludNull}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>

                        <!-- Valeurs absolues -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="CheckAbsoluteValues" Width="20" Height="20" VerticalAlignment="Center"
                      IsChecked="True" Checked="GlobalRefreshButton_Click" Unchecked="GlobalRefreshButton_Click"/>
                            <TextBlock Text="{lang:Loc AbsoluteValue}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>


                <Button x:Name="ParameterButton" Grid.Column="6" Width="15" Padding="0" Margin="5,0" Height="30" Click="OpenSupplementaryParams_Click" VerticalAlignment="Top" ToolTip="Paramètres supplémentaires"
                         >
                    <TextBlock Text="⋮" FontSize="30" Margin="1,-3,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,0"   x:Name="NoDataImage">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Image  Width="auto" Height="auto" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Source="/Asset/EmptyData.jpg" Margin="0" Stretch="Uniform" Visibility="Visible" Panel.ZIndex="999" />
                <TextBlock Grid.Row="1" Text="Pas de données pour le moment..." Style="{StaticResource EmptyDataTextBlockStyle}" />

            </Grid>

            <!-- Zone graphique -->
            <ScrollViewer Grid.Row="1" Visibility="Visible" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                <lvc:CartesianChart x:Name="BarChart" Series="{Binding Series}" TooltipPosition="Auto"   Title="{Binding Title}" ZoomMode="X" ZoomingSpeed="0"
                                    Panel.ZIndex="998">
                  
                </lvc:CartesianChart>
            </ScrollViewer>


            
        </Grid>
    </GroupBox>
</UserControl>
