<Window x:Class="TOLTECH_APPLICATION.Front.SelectFloatingPanelDB"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TOLTECH_APPLICATION.Front"
        mc:Ignorable="d"
        Title="SelectFloatingPanelDB" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Bandeau supérieur -->
            <RowDefinition Height="*"/>
            <!-- DataGrid prenant tout l'espace restant -->
            <RowDefinition Height="Auto"/>
            <!-- Bouton en bas -->
        </Grid.RowDefinitions>

        <!-- Bandeau supérieur -->
        <Border Background="#2D3E50" Padding="15" Margin="5" CornerRadius="6" Grid.Row="0">
            <TextBlock Text="Liste des tolérances du modèle actif" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Border>

        <!-- DataGrid : le scroll vertical est géré par le DataGrid -->
        <DataGrid x:Name="ToleranceGrid" Grid.Row="1" Margin="15" AutoGenerateColumns="False"
              AlternatingRowBackground="#E9EDF2" RowBackground="White" GridLinesVisibility="All"
              HeadersVisibility="Column" CanUserAddRows="True" CanUserDeleteRows="False" CanUserResizeRows="False"
              IsReadOnly="False" FontSize="14" ColumnHeaderHeight="35" RowHeight="30" BorderThickness="0"
              SelectionMode="Extended" SelectionUnit="FullRow"  >

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Link DB" Click="SelectToleranceButton_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <!--<DataGridTemplateColumn Header="tolInt">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding tolInt, StringFormat='±{0:N2}'}" />
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>-->



            <DataGrid.Resources>
                <!-- En-tête -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3A4C63"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <!-- Cellules -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,2"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </DataGrid.Resources>
        </DataGrid>

        <!-- Bouton Enregistrer en bas, toujours visible -->
        <!--<Button Content="Enregistrer" Width="120" Height="30" Margin="10"
            HorizontalAlignment="Right" VerticalAlignment="Center" Click="SaveButton_Click" Grid.Row="2"/>-->
    </Grid>
</Window>
