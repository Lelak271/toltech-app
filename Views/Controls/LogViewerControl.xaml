<UserControl x:Class="TOLTECH_APPLICATION.FrontEnd.Controls.LogViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
             xmlns:lang="clr-namespace:TOLTECH_APPLICATION.Resources.Lang"
             xmlns:local="clr-namespace:TOLTECH_APPLICATION.FrontEnd.Controls"
             xmlns:conv="clr-namespace:TOLTECH_APPLICATION.Converters"
             mc:Ignorable="d"
             MinHeight="30" 
             Height="auto"
             >

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>

        <!-- Bandeau compact -->
        <Border Grid.Row="0" MinHeight="25" MaxHeight="25"
                BorderThickness="0,0,0,1" VerticalAlignment="Top" >
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{DynamicResource SecondaryBackgroundColor}" Opacity="0.95"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
         
            <DockPanel LastChildFill="True"
                       VerticalAlignment="Center"
                       Margin="8,0">
                <ToggleButton Content="Logs"
                          IsChecked="{Binding IsExpanded}"
                          DockPanel.Dock="Right"
                          Height="20"
                          Padding="6,0"
                          VerticalAlignment="Center"/>
                <Button Content="🗑"
                         Command="{Binding EraseCommand}"
                          DockPanel.Dock="Right"
                          Height="20"
                          Padding="6,0"
                          VerticalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsExpanded,
                        Converter={StaticResource BoolToVisibilityConverter}}">

                    <CheckBox IsChecked="{Binding ShowInfo, Mode=TwoWay}" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icône Info -->
                                <TextBlock Text="ℹ️" Foreground="DodgerBlue" Margin="0,0,4,0"/>
                                <TextBlock Text="{lang:Loc InfoTitle}" Foreground="DodgerBlue" VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding ShowWarning, Mode=TwoWay}" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icône Warning -->
                                <TextBlock Text="⚠️" Foreground="LightCoral" Margin="0,0,4,0"/>
                                <TextBlock Text="{lang:Loc Warning}" Foreground="LightCoral" VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding ShowError, Mode=TwoWay}" VerticalAlignment="Center" FontSize="11" Margin="0,0,8,0">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icône Error -->
                                <TextBlock Text="❌" Foreground="Red" Margin="0,0,4,0"/>
                                <TextBlock Text="{lang:Loc Error}" Foreground="Red" VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>

                    <CheckBox IsChecked="{Binding ShowDebug, Mode=TwoWay}" VerticalAlignment="Center" FontSize="11">
                        <CheckBox.Content>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icône Debug -->
                                <TextBlock Text="🐞" Foreground="Turquoise" Margin="0,0,4,0"/>
                                <TextBlock Text="{lang:Loc Debug}" Foreground="Turquoise"  VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox.Content>
                    </CheckBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"         
              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
               >
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{DynamicResource SecondaryBackgroundColor}" Opacity="0.95"/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
                <ListBox x:Name="LogsListBox"
                         ItemsSource="{Binding LogsView}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch">
                    
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="3"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Level}"
                                   FontWeight="Bold"
                                   Width="70"/>
                                <TextBlock Text="{Binding Message}"
                                   Margin="5,0,0,0"
                                   TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Source}"
                                   Margin="5,0,0,0"
                                   FontStyle="Italic"
                                   Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

        </Grid>

        <!--<Border Grid.Row="2" MinHeight="25" Height="25"
        BorderThickness="0,0,0,1" VerticalAlignment="Top" Background="DarkRed" >
        </Border>-->
        
    </Grid>
</UserControl>
