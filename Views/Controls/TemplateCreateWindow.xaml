<Window x:Class="TOLTECH_APPLICATION.FrontEnd.Controls.TemplateCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TOLTECH_APPLICATION.FrontEnd.Controls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="TemplateCreateWindow" Height="250" Width="450"
         Background="{DynamicResource DialogBackground}"
        Loaded="TemplateMsgWindow_Loaded">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Image et texte adaptatifs -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Image x:Name="DialogImage" Width="48" Height="48" Margin="0,0,10,0"/>
            <TextBlock x:Name="DialogText" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
        </StackPanel>
        <Button Content="🎲 Random" Grid.Row="1" Width="auto" Margin="0,0,5,0" IsDefault="True" Click="BtnRandom_Click" HorizontalAlignment="Right"/>
        <TextBox x:Name="TextBoxName" Grid.Row="2" VerticalContentAlignment="Center" Height="40" FontSize="16"/>

        <!-- Boutons OK / Cancel -->
        <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="0,0,5,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
