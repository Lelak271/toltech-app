<Window x:Class="Toltech.App.FrontEnd.Controls.LoadingWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Toltech.App.FrontEnd.Controls"
             mc:Ignorable="d" 
             ResizeMode="NoResize"
             WindowStartupLocation="CenterScreen"
             Height="150" Width="350">
    <Grid>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
            <TextBlock Text="Calcul en cours..." FontSize="16" Margin="0,0,0,10"/>
            <ProgressBar x:Name="ProgressBarCalc" Height="20" Width="300" IsIndeterminate="True" Margin="15,0" />
            <TextBlock x:Name="ProgressMessage" Text="Démarrage..." FontSize="14"  HorizontalAlignment="Center"
                       TextAlignment="Center"  Margin="0,10"/>
        </StackPanel>
    </Grid>
</Window>